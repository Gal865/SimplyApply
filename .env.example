# Private app access. Set these in Vercel for Production and Preview.
APP_USERNAME=shortlist
APP_PASSWORD=replace-with-a-long-random-password
APP_OWNER_EMAIL=you@example.com

# Server-only integrations. Mark secret values as Sensitive in Vercel.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JSEARCH_API_KEY=your-rapidapi-key
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=your-model-id

# Public URL sent as attribution to OpenRouter.
PUBLIC_SITE_URL=https://your-project.vercel.app
